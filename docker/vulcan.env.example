# logging
VULCAN_LOG_LEVEL=INFO
VULCAN_JSON_LOGS=true

# comma delimit CORS allow-list
# leave empty to disable browser cross-origin access
VULCAN_CORS_ORIGINS=

# X-API-Token: <token>
# Authorization: Bearer <token>
VULCAN_API_TOKEN=

# max body size (bytes)
# default 1 MiB
VULCAN_MAX_CONTENT_LENGTH=1048576

# rate limits
VULCAN_RATE_LIMIT_DEFAULT=60/minute
VULCAN_RATE_LIMIT_CREATE_PCAP=10/minute
# can sub for redis here 
VULCAN_RATE_LIMIT_STORAGE_URI=memory://

# gunicorn
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=30
